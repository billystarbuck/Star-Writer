{% comment %}
  Installed immediately before </body> in the active Shopify theme's
  layout/theme.liquid file. This corrects stale cached page copies without
  affecting any other page or link.
{% endcomment %}
{% if request.path == '/pages/free-ai-writing-tool' %}
  <script>
    (function ensureStarWriterDownloaderLink() {
      const downloadUrl = 'https://github.com/billystarbuck/Star-Writer/releases/download/v0.77-beta/Star.Writer.Beta.Downloader.exe';
      const liteDownloadUrl = 'https://github.com/billystarbuck/Star-Writer/releases/download/v0.76.1-lite-beta/Star.Writer.Lite.Beta.Downloader.exe';
      const updateUrl = 'https://github.com/billystarbuck/Star-Writer/releases/download/v0.77-beta/Star.Writer.Update.0.77.exe';
      const updateDownloadLink = () => {
        document.querySelectorAll('a').forEach((link) => {
          if (/^Download Star Writer 0\.77 Beta$/.test(link.textContent.trim())) {
            link.href = downloadUrl;
          }
          if (/^Download Star Writer Lite\b/.test(link.textContent.trim())) {
            link.href = liteDownloadUrl;
          }
          if (/^Download Star Writer 0\.77 Update$/.test(link.textContent.trim())) {
            link.href = updateUrl;
          }
        });
      };

      document.addEventListener('DOMContentLoaded', updateDownloadLink);
      document.addEventListener('shopify:section:load', updateDownloadLink);
      updateDownloadLink();
    })();
  </script>
{% endif %}
